ratios = []
distances = []

context_strengths = [0.1, 0.5, 1.0, 2.0, 3.0]
num_trials = 3

for strength in context_strengths:

    trial_distances = []
    trial_ratios = []

    for trial in range(num_trials):

        # --- Context setup ---
        context_A = np.zeros(N)
        context_B = np.zeros(N)

        idx = np.random.choice(N, 2, replace=False)

        context_A[idx[0]] = strength
        context_A[idx[1]] = -strength

        context_B[idx[0]] = -strength
        context_B[idx[1]] = strength

        # --- Run simulations ---
        z_A = run_simulation(I, W, context_A, T, N, dt, tau, noise_level)
        z_B = run_simulation(I, W, context_B, T, N, dt, tau, noise_level)

        # --- Population distance ---
        distance_time = np.sqrt(np.sum((z_A - z_B)**2, axis=1) / N)
        distance = np.mean(distance_time[1150:1300])  # post-stimulus window

        trial_distances.append(distance)

        # --- Norms ---
        input_norm = np.mean([np.linalg.norm(I[t, :]) for t in range(1100, 1300)])
        context_norm = np.linalg.norm(context_A)

        if context_norm == 0:
            ratio = 0
        else:
            ratio = input_norm/context_norm

        trial_ratios.append(ratio)

    # average across trials
    distances.append(np.mean(trial_distances))
    ratios.append(np.mean(trial_ratios))


# --- Plot ---
plt.figure()
plt.plot(ratios, distances, marker='o')
plt.xlabel("Input / Context Norm Ratio")
plt.ylabel("Mean Population Distance (post stimulus)")
plt.title("Generalization vs Differentiation as a Function of Relative Strength")
