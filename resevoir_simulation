ratios = []
distances = []

context_strengths = [0.1, 0.5, 1.0]
input_deltas = [0.0, 0.2, 0.4]

gain = np.random.normal(1.0, 0.1, N)

            # ----- norm of condition differences -----
input_diff_norm = np.mean([
    np.linalg.norm(I_A[t, :] - I_B[t, :]) for t in range(1100, 1300)
    ])

num_trials = 3
base_input_amp = 1.0

for context_strength in context_strengths:
    for delta_input in input_deltas:

        trial_distances = []
        trial_ratios = []

        for trial in range(num_trials):

            # ----- context difference -----
            context_A = np.zeros(N)
            context_B = np.zeros(N)

            idx = np.random.choice(N, 2, replace=False)

            context_A[idx[0]] = context_strength
            context_A[idx[1]] = -context_strength

            context_B[idx[0]] = -context_strength
            context_B[idx[1]] = context_strength

            # ----- input difference -----
            x_A = np.zeros(T)
            x_B = np.zeros(T)

            x_A[1100:1150] = base_input_amp + delta_input
            x_B[1100:1150] = base_input_amp - delta_input

            I_A = np.zeros((T, N))
            I_B = np.zeros((T, N))

            for t in range(T):
                I_A[t, :] = x_A[t] * gain
                I_B[t, :] = x_B[t] * gain

            # ----- run simulations -----
            z_A = run_simulation(I_A, W, context_A, T, N, dt, tau, noise_level)
            z_B = run_simulation(I_B, W, context_B, T, N, dt, tau, noise_level)

            # ----- population distance -----
            distance_time = np.sqrt(np.sum((z_A - z_B) ** 2, axis=1) / N)
            mean_distance = np.mean(distance_time[1150:1300])



            context_diff_norm = np.linalg.norm(context_A - context_B)

            ratio = input_diff_norm / context_diff_norm

            trial_distances.append(mean_distance)
            trial_ratios.append(ratio)

        distances.append(np.mean(trial_distances))
        ratios.append(np.mean(trial_ratios))

plt.figure()
plt.scatter(ratios, distances)
plt.xlabel("||I_A - I_B|| / ||c_A - c_B||")
plt.ylabel("Mean population distance (post stimulus)")
plt.title("Population separation vs relative input/context difference")
