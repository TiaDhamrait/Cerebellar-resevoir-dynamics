context_A[idx[0]] = 1
context_A[idx[1]] = -1
context_B[idx[0]]= -1
context_B[idx[1]] = 1

I = np.zeros((T, N))

for t in range(T):
  for i in range(N):
    I[t, i] = max(0.0, I0[i] + f[i] *0.1*I0[i] * x[t])

## MAIN EQUATION LOOP

def run_simulation(I, W, context_vector, T, N, dt, tau, noise_level, noise_matrix=None):
    """Simulates the recurrent network trajectory over time with synaptic decay.

    This function executes the main equation loop for the reservoir model, applying
    time-series external inputs, fixed recurrent weights, historical decay factors, 
    and explicit contextual vectors to calculate population firing rates at each step.

    Parameters
    ----------
    I : numpy.ndarray
        Shape (T, N) matrix representing external stimulus inputs for each neuron over time.
    W : numpy.ndarray
        Shape (N, N) connectivity weight matrix representing recurrent inhibitory connections.
    context_vector : numpy.ndarray
        Shape (N,) vector containing the specific contextual perturbation values.
    T : int
        Total number of discrete time steps to execute in the simulation.
    N : int
        Total number of neurons comprising the recurrent network population.
    dt : float
        The temporal step size (increment) utilized for integration (e.g., 0.001 seconds).
    tau : float
        Synaptic decay time constant dictating the exponential loss of past network activity.
    noise_level : float
        Scaling factor defining the amplitude variance of random Gaussian noise.
    noise_matrix : numpy.ndarray, optional
        Pre-generated shape (T, N) matrix to apply consistent noise conditions across trials.

    Returns
    -------
    numpy.ndarray
        Shape (T, N) matrix containing the calculated firing rates for all neurons 
        across every simulated time step.
    """  
  
  z = np.zeros((T, N))

  for t in range(1, T):
    start = max(1, t-100)
    small_sum = np.zeros(N)

    if noise_matrix is not None:
      noise = noise_matrix[t]
    else:
      noise = noise_level * np.random.normal(0, 0.5, N)

    for s in range(start, t+1):
      decay = np.exp(-((t-s)*dt)/tau)
      small_sum += decay*z[s-1]

    z[t] = np.maximum(0.0, I[t] + context_vector - decay * np.matmul(W, small_sum) + noise)

  return z

## Controlled noise

noise_matrix = noise_level * np.random.normal(0, 0.5, (T, N))

