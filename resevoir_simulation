A = (np.random.rand(N,N) < connection_prob).astype(float) # NXN matrix of random numbers between 0 and 1
W = A * (2 * weight_strength / N) # all inhibitory weights are positive; normalization implemented

## EXTERNAL INPUT

x = np.zeros(T) # one input signal over time
x[1100:1150] = 1 # 50 ms pulse when dt = 1 ms

I0 = np.random.normal(1.0, 0.1, N) # baseline input for each neuron

f = np.ones(N)
f[:N//2] = -1 # half the neurons decrease instead of increase
np.random.shuffle(f)

# Context Vectors

